{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "provider": {
    "perplexity": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Perplexity",
      "options": {
        "baseURL": "https://api.perplexity.ai",
        "apiKey": "{env:PERPLEXITY_API_KEY}"
      },
      "models": {
        "sonar-pro": {
          "id": "sonar-pro"
        }
      }
    }
  },
  "instructions": [
    "./instructions/core.md",
    "./instructions/mindset.md"
  ],
  "default_agent": "plan",
  "agent": {
    "plan": {
      "description": "Analyze code and create step-by-step plans without making changes.",
      "mode": "primary",
      "model": "github-copilot/claude-haiku-4.5",
      "max_steps": 5,
      "prompt": "./instructions/planner.md",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": {
          "*": "deny"
        }
      }
    },
    "build": {
      "description": "Execute plans with precise, minimal changes to code.",
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.6",
      "max_steps": 16,
      "prompt": "./instructions/implementer.md",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git diff *": "allow",
          "rg *": "allow"
        },
        "task": {
          "*": "deny"
        }
      }
    },
    "coder": {
      "description": "Subagent for simple, isolated edits: config changes, renames, comment updates, single-file fixes.",
      "mode": "subagent",
      "model": "github-copilot/claude-haiku-4.5",
      "max_steps": 8,
      "prompt": "./instructions/coder.md",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git diff *": "allow",
          "rg *": "allow"
        },
        "task": {
          "*": "deny"
        }
      }
    },
    "review": {
      "description": "Subagent for code review: checks patterns, potential issues, and improvements. Read-only.",
      "mode": "subagent",
      "model": "github-copilot/claude-haiku-4.5",
      "max_steps": 5,
      "prompt": "./instructions/reviewer.md",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git diff *": "allow",
          "rg *": "allow"
        },
        "task": {
          "*": "deny"
        }
      }
    },
    "researcher": {
      "description": "Research agent using Perplexity for real-time web search. Saves findings to .research-notes.md.",
      "mode": "subagent",
      "model": "perplexity/sonar-pro",
      "max_steps": 3,
      "prompt": "./instructions/researcher.md",
      "permission": {
        "edit": {
          ".research-notes.md": "allow"
        },
        "bash": "deny"
      }
    }
  }
}
